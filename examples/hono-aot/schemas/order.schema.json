{
  "$id": "https://example.com/order",
  "type": "object",
  "properties": {
    "orderId": { "type": "string", "pattern": "^ORD-[0-9]{8}$" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "sku": { "type": "string" },
          "qty": { "type": "integer", "minimum": 1 }
        },
        "required": ["sku", "qty"]
      }
    }
  },
  "required": ["orderId", "items"]
}
